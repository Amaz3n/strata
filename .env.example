# App URL used for OAuth redirects. Production must be HTTPS and match Intuit exactly.
NEXT_PUBLIC_APP_URL=https://app.example.com

# Supabase project connection. Publishable/legacy anon keys are safe for public clients;
# the service-role key is server-only and must never be included in the iOS app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# QuickBooks Online OAuth credentials.
# Use sandbox credentials with QBO_SANDBOX=true.
# Use production credentials with QBO_SANDBOX=false.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_SANDBOX=false
QBO_WEBHOOK_VERIFIER_TOKEN=

# Stripe webhook signing secrets. Use STRIPE_WEBHOOK_SECRET for platform account events
# and STRIPE_CONNECT_WEBHOOK_SECRET for connected-account events.
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Server-side token encryption key. Must be 32 bytes raw, 64 hex chars, or base64 for 32 bytes.
TOKEN_ENCRYPTION_KEY=

# Cron/API protection for background QBO processors.
CRON_SECRET=

# Codex-backed platform issue review. CODEX_REVIEW_GITHUB_TOKEN needs permission
# to dispatch workflows for CODEX_REVIEW_GITHUB_REPOSITORY, e.g. owner/repo.
# CODEX_REVIEW_CALLBACK_SECRET must match the GitHub secret
# ARC_CODEX_REVIEW_CALLBACK_SECRET used by .github/workflows/codex-bug-review.yml.
CODEX_REVIEW_GITHUB_REPOSITORY=
CODEX_REVIEW_GITHUB_REF=main
CODEX_REVIEW_GITHUB_TOKEN=
CODEX_REVIEW_CALLBACK_SECRET=

# Sentry error tracking. Use the public DSN for browser capture and the private
# DSN for server/worker capture when available.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1

# Apple Push Notification service for the native iOS app.
# The .p8 private key should be stored with escaped newlines (\n) when entered
# as a single environment variable.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_AUTH_KEY=
APNS_BUNDLE_ID=com.arcprojects.mobile
APNS_ENVIRONMENT=production
