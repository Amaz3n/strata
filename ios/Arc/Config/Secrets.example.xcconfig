// Secrets.example.xcconfig
// Copy this file to "Secrets.xcconfig" (same folder) and fill in the values.
// Secrets.xcconfig is git-ignored so your local copy never gets committed.
//
// These are the ONLY values the iOS app needs from your big pile of env vars —
// and all of them are PUBLIC (client-safe). Everything else (service-role keys,
// Stripe secret, QBO secrets, R2 keys, drawings-tiles secret, …) stays on the
// server and is reached only through /api/mobile/v1. Do not copy those here.
//
// Reminder: protect every "//" in a URL with "$()" — see Shared.xcconfig.

// Optional Supabase project URL override, e.g. https:/$()/abcdefgh.supabase.co
ARC_SUPABASE_URL =

// Optional Supabase publishable (anon) key override — safe to ship in the client.
ARC_SUPABASE_PUBLISHABLE_KEY =

// Optional: Sentry DSN for crash/error reporting. Leave blank to disable.
ARC_SENTRY_DSN =
