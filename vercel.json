{
  "crons": [
    {
      "path": "/api/qbo/process-outbox",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/qbo/process-webhooks",
      "schedule": "5 2 * * *"
    },
    {
      "path": "/api/qbo/process-cdc",
      "schedule": "10 2 * * *"
    },
    {
      "path": "/api/jobs/process-outbox",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/jobs/rbac-evidence",
      "schedule": "15 2 * * *"
    },
    {
      "path": "/api/jobs/weekly-executive-snapshot",
      "schedule": "0 13 * * 5"
    },
    {
      "path": "/api/jobs/follow-up-reminders",
      "schedule": "0 13 * * *"
    }
  ],
  "functions": {
    "app/(app)/drawings/actions.ts": {
      "maxDuration": 30
    },
    "app/api/jobs/process-outbox/route.ts": {
      "maxDuration": 300
    },
    "app/api/qbo/process-outbox/route.ts": {
      "maxDuration": 120
    },
    "app/api/qbo/process-webhooks/route.ts": {
      "maxDuration": 120
    },
    "app/api/qbo/process-cdc/route.ts": {
      "maxDuration": 120
    },
    "app/api/jobs/rbac-evidence/route.ts": {
      "maxDuration": 60
    },
    "app/api/jobs/weekly-executive-snapshot/route.ts": {
      "maxDuration": 300
    },
    "app/api/jobs/follow-up-reminders/route.ts": {
      "maxDuration": 120
    }
  }
}
